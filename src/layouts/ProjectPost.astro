---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import StylizedSeparator from '../components/StylizedSeparator.astro';
import { slugify, withBase } from '../utils/slugify';
import '../styles/layouts/project-post.css';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	Content?: any;
	tags?: string[];
	category?: 'work' | 'personal';
	personalCategory?: 'cyberdeck' | 'nas' | 'crafts' | 'other';
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], Content, category = 'personal', personalCategory } = Astro.props as Props;

const categoryLabels = {
	work: 'Work',
	personal: 'Personal',
} as const;

const personalCategoryLabels = {
	cyberdeck: 'Cyberdeck',
	nas: 'NAS',
	crafts: 'Crafts',
	other: 'Other',
} as const;

const eyebrow = category === 'personal' && personalCategory
	? `${categoryLabels[category]} · ${personalCategoryLabels[personalCategory]}`
	: categoryLabels[category];
---

<BaseLayout title={title} description={description} image={heroImage}>
	<div class="project-post-layout">
	<article class="project-post">
		<header class="project-post__heading">
			<p class="project-post__eyebrow"><StylizedSeparator text={eyebrow} /></p>
			<h1>{title}</h1>
			<p class="project-post__meta">
				<FormattedDate date={pubDate} />
				{updatedDate && (
					<span>
						&middot; Updated <FormattedDate date={updatedDate} />
					</span>
				)}
			</p>
			{tags.length > 0 && (
				<ul class="project-post__tags">
					{tags.map((tag) => (
						<li class="project-post__tag">
							<a href={withBase(`/tags/${slugify(tag)}/`)}>{tag}</a>
						</li>
					))}
				</ul>
			)}
		</header>

		{heroImage && (
			<figure class="project-post__hero-image">
				<Image width={1020} height={510} src={heroImage} alt="" />
			</figure>
		)}

		<section class="project-post__article">
			<Prose>
				{Content ? <Content /> : <slot />}
			</Prose>
		</section>
	</article>
	</div>
</BaseLayout>
