---
/**
 * SectionList.astro
 *
 * Reusable section component for lists like "Education", "Teaching", "Speaking", etc.
 *
 * Props:
 *  - heading: string
 *  - items: Array<{
 *      title: string;
 *      description?: string;
 *      datetime?: string; // value for the `datetime` attribute on <time>
 *      dateLabel?: string; // what to render inside <time>, defaults to `datetime`
 *    }>
 *
 * Slots:
 *  - default: (optional) any extra content to render after the items (e.g. "View all" link)
 */
import StylizedSeparator from './StylizedSeparator.astro';
import '../styles/components/section-list.css';

interface Item {
    title: string;
    description?: string;
    datetime?: string;
    dateLabel?: string;
    href?: string;
    target?: string;
    rel?: string;
    external?: boolean;
}

export interface Props {
    heading: string;
    items: Item[];
}

const heading: string = Astro.props.heading;
const items: Item[] = Astro.props.items ?? [];

function isExternal(href: string) {
    return /^https?:\/\//i.test(href);
}
---

<section class="section-list">
    <div class="section-list__inner">
        <div class="section-list__grid">
            <div class="section-list__heading">
                <h2 class="section-list__title">
                    {heading}
                </h2>
            </div>

            <div class="section-list__items">
                {
                    items.map((item) => (
                        <article class="section-list__item">
                            <div class="section-list__item-body">
                                <h3 class="section-list__item-title">
                                    {item.href ? (
                                        <a
                                            href={item.href}
                                            target={
                                                item.target ??
                                                ((item.external ??
                                                isExternal(item.href))
                                                    ? "_blank"
                                                    : undefined)
                                            }
                                            rel={
                                                item.rel ??
                                                ((item.external ??
                                                isExternal(item.href))
                                                    ? "noopener noreferrer"
                                                    : undefined)
                                            }
                                        >
                                            <span class="section-list__link-hitbox" />
                                            <span class="section-list__link-label">
                                                <StylizedSeparator text={item.title} />
                                            </span>
                                        </a>
                                    ) : (
                                        <StylizedSeparator text={item.title} />
                                    )}
                                </h3>
                                {item.description && (
                                    <p class="section-list__description">
                                        {item.description}
                                    </p>
                                )}
                            </div>

                            {item.datetime && (
                                <p class="section-list__date">
                                    <time datetime={item.datetime}>
                                        {item.dateLabel ?? item.datetime}
                                    </time>
                                </p>
                            )}
                        </article>
                    ))
                }

                <!-- Slot for optional extra content, e.g. "View all" link -->
                <slot />
            </div>
        </div>
    </div>
</section>
