---
/**
 * ProjectList.astro
 *
 * Reusable work section component.
 *
 * Props:
 * - heading?: string (default: "Work")
 * - items: Array of project-like objects. Each item may be either:
 *     - a plain object: { title, description?, link?, image? }
 *     - a collection item: { data: { title, description?, link?, image? } }
 * - limit?: number (default: 4) -> how many items to show
 * - viewAllHref?: string -> optional "View all work" link
 * - viewAllLabel?: string (default: "View all work")
 *
 * Slots:
 * - default: optional slot rendered in the same spot as the "View all" link
 *
 * Behavior:
 * - Renders the same markup/styling as the original index Projects section.
 * - Link targets to external URLs get `target="_blank"` and `rel="noopener noreferrer"`.
 */
import Card from "./Card.astro";
import { getCollection } from 'astro:content';
import { projectPath } from '../utils/projectRoutes';
import { withBase } from '../utils/slugify';
import '../styles/components/project-list.css';

interface RawProject {
    // Either the flattened shape...
    title?: string;
    description?: string;
    link?: string;
    image?: any;
    heroImage?: any;
    category?: 'work' | 'personal';
    personalCategory?: string;

    // ...or the content collection shape:
    data?: {
        title?: string;
        description?: string;
        link?: string;
        image?: any;
        heroImage?: any;
        category?: 'work' | 'personal';
        personalCategory?: string;
        pubDate?: Date | string;
    };
}

export interface Props {
    heading?: string;
    items: RawProject[];
    limit?: number;
    viewAllHref?: string;
    viewAllLabel?: string;
}

let {
    heading = "Work",
    items = [],
    limit = 4,
    viewAllHref,
    viewAllLabel = "View all work",
} = Astro.props as Props;

function getProjectData(item: RawProject) {
    return item && (item as any).data ? (item as any).data : item;
}

if (items.length === 0) {
    console.warn('[ProjectList] No items provided; fetching work entries from "projects" collection.');
    items = items.concat(
        ((await getCollection("projects")) as RawProject[])
            .filter((project) => getProjectData(project).category === 'work'),
    ).sort((a, b) => {
        const aDate = getProjectData(a).pubDate;
        const bDate = getProjectData(b).pubDate;
        return new Date(bDate ?? 0).valueOf() - new Date(aDate ?? 0).valueOf();
    });
}

const visibleItems = typeof limit === "number" ? items.slice(0, limit) : items;

const categoryLabels = {
    work: 'Work',
    personal: 'Personal',
} as const;

const personalCategoryLabels: Record<string, string> = {
    cyberdeck: 'Cyberdeck',
    nas: 'NAS',
    crafts: 'Crafts',
    other: 'Other',
};

const baseUrl =
    !import.meta.env.BASE_URL || import.meta.env.BASE_URL === "/"
        ? ""
        : import.meta.env.BASE_URL;
---

<section class="project-list">
    <div class="project-list__inner">
        <div class="project-list__grid">
            <div class="project-list__heading">
                <h2 class="project-list__title">
                    {heading}
                </h2>
            </div>

            <div class="project-list__items">
                {
                    visibleItems.map((item) => {
                        const p = getProjectData(item) || {};
                        const id = (item as any).id;
                        const href = id ? withBase(projectPath(id, p.category)) : (p.link ?? withBase('/work/'));
                        const category = p.category as keyof typeof categoryLabels | undefined;
                        const eyebrow = category
                            ? category === 'personal' && p.personalCategory
                                ? `${categoryLabels[category]} · ${personalCategoryLabels[p.personalCategory] ?? p.personalCategory}`
                                : categoryLabels[category]
                            : undefined;

                        return (
                            <Card
                                title={p.title}
                                href={href}
                                image={p.heroImage ?? p.image}
                                imageAlt={p.title}
                                description={p.description}
                                eyebrow={eyebrow}
                                variant="project"
                                cta="View project →"
                            />
                        );
                    })
                }
                <Card
                    title={viewAllLabel}
                    href={`${baseUrl + (viewAllHref ?? '/work/')}`}
                    variant="project"
                />
            </div>
        </div>
    </div>
</section>
