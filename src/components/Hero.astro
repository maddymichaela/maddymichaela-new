---
interface Action {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";
import WarpBackground from "./WarpBackground";
import "../styles/components/hero.css";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;
---

<section class="home-hero">
  <div class="home-hero__background" aria-hidden="true">
    <WarpBackground client:load />
  </div>

  <div class="home-hero__masthead">
    <div class="home-hero__title-row">
      <div
        class="home-hero__letters"
        aria-hidden="true"
      >
        {title}
      </div>
    </div>
  </div>

  <div class="home-hero__content">
    <div class="home-hero__grid">
      <div>
        {role && <h1 class="home-hero__role">{role}</h1>}
      </div>

      <div class="home-hero__summary">
        {description && <p class="home-hero__description">{description}</p>}
        {location && <p class="home-hero__location">{location}</p>}
      </div>

      <div class="home-hero__action-cell">
        {actions.length > 0 && (
          <div class="home-hero__actions">
            {actions.map((action) => (
              isExternal(action.href) ? (
                <a
                  class="home-hero__action"
                  href={action.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {action.label}
                </a>
              ) : (
                <a
                  class="home-hero__action"
                  href={withBase(action.href)}
                >
                  {action.label}
                </a>
              )
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
