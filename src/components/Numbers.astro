---
interface Stat {
  label: string;
  value: string;
  description?: string;
  delta?: string;
}

interface Props {
  title?: string;
  eyebrow?: string;
  copy?: string;
  stats?: Stat[];
}

const {
  title = 'By the numbers',
  eyebrow,
  copy,
  stats = [],
} = Astro.props as Props;

import '../styles/components/numbers.css';
---

<section class="numbers">
  <header class="numbers__header">
    {eyebrow && <p class="numbers__eyebrow">{eyebrow}</p>}
    {title && <h2 class="numbers__title">{title}</h2>}
    {copy && <p class="numbers__copy">{copy}</p>}
  </header>

  {stats.length > 0 && (
    <div class="numbers__grid">
      {stats.map((stat) => (
        <div class="numbers__card">
          <div class="numbers__value-row">
            <p class="numbers__value">{stat.value}</p>
            {stat.delta && <span class="numbers__delta">{stat.delta}</span>}
          </div>
          <p class="numbers__label">{stat.label}</p>
          {stat.description && <p class="numbers__description">{stat.description}</p>}
        </div>
      ))}
    </div>
  )}
</section>
