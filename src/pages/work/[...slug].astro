---
import { getCollection, render } from 'astro:content';
import ProjectPost from '../../layouts/ProjectPost.astro';
import { findProjectByRouteSlug } from '../../utils/projectRoutes';

const slug = Astro.params.slug;
const projects = await getCollection('projects');
const project = findProjectByRouteSlug(projects, slug, 'work');

if (!project) {
	return Astro.redirect('/work/');
}

const { Content } = await render(project);
---
<ProjectPost {...project.data}>
	<Content />
</ProjectPost>
