---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/Hero.astro";
import PostList from "../components/PostList.astro";
import SectionList from "../components/SectionList.astro";

import { getCollection } from "astro:content";
import { getSite } from "../utils/consts";
import ProjectList from "../components/ProjectList.astro";
import Social from "../components/Social.astro";

const cv = ((await getCollection("cv" as any)) as any[]).sort((a, b) => {
	const sectionOrder = ["experience", "education"];
	const aIndex = sectionOrder.includes(a.id) ? sectionOrder.indexOf(a.id) : sectionOrder.length;
	const bIndex = sectionOrder.includes(b.id) ? sectionOrder.indexOf(b.id) : sectionOrder.length;
	return aIndex - bIndex;
});

const site = await getSite();
---

<PageLayout title={site.author.name || "Madeline Lim"}>
	<Hero
		title={site.author.name || "Madeline Lim"}
		description={site.author.bio || "UIUX Designer/Developer Portfolio"}
		role={site.author.role}
		location={site.author.location}
		actions={[
			{ label: "Github", href: "https://github.com/maddymichaela" },
			{
				label: "Linkedin",
				href: "https://www.linkedin.com/in/maddymichaela/",
			},
			{ label: "Contact", href: "mailto:hello@maddymichaela.com" },
		]}
	/>

	<!-- <Social class="mt-8" /> -->

	<ProjectList heading="Work" limit={4} viewAllHref="/work" />

	<PostList
		heading="Personal Projects"
		limit={3}
		viewAllHref="/personal-projects"
	/>

	<!-- Sections (from src/content/cv.yml) -->
	{
		cv.map((section) => {
			if (section.data.items) {
				return (
					<SectionList
						heading={section.data.heading}
						items={section.data.items}
					/>
				);
			}
			return null;
		})
	}
</PageLayout>
