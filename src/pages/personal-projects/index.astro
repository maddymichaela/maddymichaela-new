---
import { getCollection } from 'astro:content';
import Card from '../../components/Card.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { getSite } from '../../utils/consts';
import { slugify, withBase } from '../../utils/slugify';

const site = await getSite();
const projects = (await getCollection('projects'))
	.filter((project) => project.data.category === 'personal')
	.sort((a, b) => {
		if (Number(b.data.featured) !== Number(a.data.featured)) {
			return Number(b.data.featured) - Number(a.data.featured);
		}
		return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
	});

const categoryLabels: Record<string, string> = {
	cyberdeck: 'Cyberdeck',
	nas: 'NAS',
	crafts: 'Crafts',
	other: 'Other',
};

const groupedProjects = ['cyberdeck', 'nas', 'crafts', 'other']
	.map((category) => ({
		category,
		label: categoryLabels[category],
		items: projects.filter((project) => (project.data.personalCategory ?? 'other') === category),
	}))
	.filter((group) => group.items.length > 0);
---

<PageLayout title={`Personal Projects · ${site.author?.name ?? 'Portfolio'}`} description="Personal builds, tools, experiments, and craft projects.">
	<section class="content-shell py-12 space-y-12">
		<header class="space-y-3 max-w-3xl">
			<p class="text-sm uppercase tracking-[0.35em] text-muted">Personal Projects</p>
			<h1 class="text-4xl font-semibold text-ink">Build logs, experiments, and small obsessions</h1>
			<p class="text-muted">
				Cyberdeck experiments, home lab and NAS notes, and craft projects that show how I think through systems, materials, and everyday usability.
			</p>
		</header>

		{groupedProjects.length === 0 ? (
			<p class="text-muted">No personal projects published yet.</p>
		) : (
			<div class="space-y-16">
				{groupedProjects.map((group) => (
					<section class="space-y-6" id={slugify(group.label)}>
						<div class="flex items-end justify-between gap-4 border-b border-[color:var(--color-border)] pb-3">
							<h2 class="text-sm 2xl:text-xl text-base-900 font-bold uppercase">{group.label}</h2>
							<p class="text-sm text-muted">{group.items.length} {group.items.length === 1 ? 'project' : 'projects'}</p>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
							{group.items.map((project) => (
								<Card
									title={project.data.title}
									href={withBase(`/projects/${project.id}/`)}
									description={project.data.description}
									date={project.data.pubDate}
									image={project.data.heroImage}
									imageAlt={project.data.title}
									eyebrow={project.data.featured ? 'Featured' : group.label}
									variant="post"
								>
									{project.data.tags.length > 0 && (
										<div class="flex flex-wrap gap-2 pt-1 text-sm text-muted">
											{project.data.tags.map((tag) => (
												<a class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 hover:text-ink" href={withBase(`/tags/${slugify(tag)}/`)}>
													{tag}
												</a>
											))}
										</div>
									)}
								</Card>
							))}
						</div>
					</section>
				))}
			</div>
		)}
	</section>
</PageLayout>
